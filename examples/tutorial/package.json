{
    "name": "tutorial",
    "version": "0.1.0",
    "private": true,
    "license": "MPL-2.0",
    "description": "Notes app from the GTKX tutorial",
    "type": "module",
    "scripts": {
        "build": "gtkx build",
        "typecheck": "tsc -b --noEmit",
        "dev": "gtkx dev",
        "start": "node dist/bundle.js",
        "bundle": "gtkx build && tsx scripts/bundle.ts",
        "bundle:postject": "tsx scripts/bundle-postject.ts",
        "build:sea": "bash scripts/build-sea.sh",
        "build:flatpak": "pnpm bundle:postject && bash flatpak/build.sh"
    },
    "dependencies": {
        "@gtkx/css": "workspace:*",
        "@gtkx/ffi": "workspace:*",
        "@gtkx/react": "workspace:*",
        "react": "^19.2.6"
    },
    "devDependencies": {
        "@gtkx/cli": "workspace:*",
        "esbuild": "^0.28.0",
        "postject": "1.0.0-alpha.6",
        "tsx": "^4.21.0"
    }
}
