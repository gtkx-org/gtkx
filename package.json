{
    "name": "gtkx",
    "version": "0.0.0",
    "private": true,
    "homepage": "https://gtkx.dev",
    "license": "MPL-2.0",
    "author": "Eugenio Depalo <eugeniodepalo@gmail.com>",
    "type": "module",
    "scripts": {
        "build": "turbo build --filter=!website --filter=!gtkx",
        "codegen": "turbo codegen:run",
        "codegen:sync": "gtkx-codegen sync",
        "codegen:run": "gtkx-codegen run",
        "docs": "turbo build --filter=website",
        "circular": "dpdm --no-warning --no-tree --transform -T --skip-dynamic-imports circular --exit-code circular:1 --exclude '(node_modules|dist|generated|out-tsc)' 'packages/{cli,codegen,css,e2e,ffi,gir,mcp,react,testing,vitest}/src/**/*.{ts,tsx}'",
        "knip": "knip",
        "lint": "turbo lint:all && turbo lint --filter=!website --filter=!gtkx",
        "lint:all": "biome check . && knip && pnpm circular",
        "coverage": "turbo coverage --filter=!website --filter=!gtkx --concurrency=1",
        "test": "turbo test --filter=!website --filter=!gtkx --concurrency=1",
        "typecheck": "turbo typecheck --filter=!website --filter=!gtkx"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.14",
        "@gtkx/codegen": "workspace:*",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@vitest/coverage-v8": "^4.1.5",
        "dpdm": "^4.0.1",
        "knip": "^6.11.0",
        "react": "^19.2.6",
        "turbo": "^2.9.9",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "packageManager": "pnpm@10.32.1"
}
