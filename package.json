{
    "name": "gtkx",
    "version": "0.0.0",
    "private": true,
    "homepage": "https://gtkx.dev",
    "license": "MPL-2.0",
    "author": "Eugenio Depalo <eugeniodepalo@gmail.com>",
    "type": "module",
    "scripts": {
        "build": "turbo build --filter=!website --filter=!gtkx",
        "codegen": "turbo codegen:run",
        "codegen:sync": "gtkx-codegen sync",
        "codegen:run": "gtkx-codegen run",
        "docs": "turbo build --filter=website",
        "lint": "turbo lint:all && turbo lint --filter=!website --filter=!gtkx",
        "lint:all": "biome check .",
        "test": "turbo test --filter=!website --filter=!gtkx --concurrency=1",
        "typecheck": "turbo typecheck --filter=!website --filter=!gtkx"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.5",
        "@gtkx/codegen": "workspace:*",
        "@types/node": "^25.3.3",
        "@types/react": "^19.2.14",
        "react": "^19.2.4",
        "tsx": "^4.21.0",
        "turbo": "^2.8.13",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "packageManager": "pnpm@10.30.3"
}
