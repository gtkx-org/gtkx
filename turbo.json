{
    "$schema": "https://turborepo.com/schema.json",
    "globalDependencies": ["tsconfig.base.json", "biome.json"],
    "globalEnv": ["NODE_VERSION", "GTK4_VERSION", "VERSION"],
    "globalPassThroughEnv": ["TURBO_TOKEN", "TURBO_TEAM"],
    "cacheDir": ".turbo",
    "tasks": {
        "//#lint:all": {
            "dependsOn": [
                "@gtkx/cli#build",
                "@gtkx/codegen#build",
                "@gtkx/css#build",
                "@gtkx/ffi#build",
                "@gtkx/gir#build",
                "@gtkx/mcp#build",
                "@gtkx/native#build",
                "@gtkx/react#build",
                "@gtkx/testing#build",
                "@gtkx/vitest#build"
            ],
            "inputs": ["**/*.ts", "**/*.tsx", "**/package.json", "biome.json", "knip.json"],
            "outputs": [],
            "outputLogs": "new-only"
        },
        "//#codegen:run": {
            "dependsOn": ["@gtkx/codegen#build"],
            "inputs": [
                "$TURBO_ROOT$/girs/**",
                "$TURBO_ROOT$/packages/gir/src/**",
                "$TURBO_ROOT$/packages/codegen/src/**"
            ],
            "outputs": ["packages/ffi/src/generated/**", "packages/react/src/generated/**"],
            "outputLogs": "new-only"
        },
        "lint": {
            "inputs": [
                "*.ts",
                "src/**/*.ts",
                "src/**/*.tsx",
                "tests/**/*.ts",
                "tests/**/*.tsx",
                "scripts/**/*.ts",
                "src/**/*.rs",
                "tests/**/*.rs"
            ],
            "outputs": [],
            "outputLogs": "new-only",
            "passThroughEnv": ["RUSTUP_TOOLCHAIN"]
        },
        "build": {
            "dependsOn": ["^build", "native-build"],
            "inputs": [
                "$TURBO_ROOT$/README.md",
                "package.json",
                "*.ts",
                "bin/**",
                "src/**/*.ts",
                "src/**/*.tsx",
                "tsconfig.json",
                "tsconfig.app.json",
                "tsconfig.lib.json",
                "tsconfig.test.json"
            ],
            "outputs": ["dist/**", "out-tsc/**", "*.tsbuildinfo", "README.md"],
            "outputLogs": "new-only"
        },
        "native-build": {
            "inputs": ["Cargo.toml", "Cargo.lock", "src/**/*.rs"],
            "outputs": [
                "index.node",
                "$TURBO_ROOT$/packages/native-linux-arm64/index.node",
                "$TURBO_ROOT$/packages/native-linux-x64/index.node"
            ],
            "outputLogs": "new-only",
            "passThroughEnv": ["RUSTUP_TOOLCHAIN", "CARGO_INCREMENTAL", "CARGO_NET_RETRY"]
        },
        "native-test": {
            "dependsOn": ["native-build"],
            "inputs": ["Cargo.toml", "src/**/*.rs"],
            "outputs": [],
            "outputLogs": "new-only",
            "passThroughEnv": ["RUSTUP_TOOLCHAIN"]
        },
        "start": {
            "dependsOn": ["build"],
            "persistent": true,
            "cache": false
        },
        "dev": {
            "dependsOn": ["^build"],
            "persistent": true,
            "cache": false
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json", "tsconfig.app.json"],
            "outputs": [],
            "outputLogs": "new-only"
        },
        "test": {
            "dependsOn": ["^build", "native-test"],
            "inputs": ["vitest.config.ts", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
            "outputLogs": "new-only"
        },
        "coverage": {
            "dependsOn": ["^build", "native-coverage"],
            "inputs": ["vitest.config.ts", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
            "outputs": ["coverage/**"],
            "outputLogs": "new-only"
        },
        "native-coverage": {
            "dependsOn": ["native-build"],
            "inputs": ["Cargo.toml", "src/**/*.rs", "tests/**/*.rs"],
            "outputs": ["coverage/**"],
            "outputLogs": "new-only",
            "passThroughEnv": ["RUSTUP_TOOLCHAIN"]
        },
        "@gtkx/ffi#test": {
            "dependsOn": ["^build", "native-test", "//#codegen:run"],
            "inputs": ["vitest.config.ts", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
            "outputLogs": "new-only"
        },
        "@gtkx/ffi#coverage": {
            "dependsOn": ["^build", "native-coverage", "//#codegen:run"],
            "inputs": ["vitest.config.ts", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
            "outputs": ["coverage/**"],
            "outputLogs": "new-only"
        },
        "@gtkx/ffi#build": {
            "dependsOn": ["^build", "//#codegen:run"],
            "inputs": ["package.json", "src/**/*.ts", "tsconfig.json", "tsconfig.lib.json", "tsconfig.test.json"],
            "outputs": ["dist/**", "out-tsc/**", "*.tsbuildinfo", "README.md"],
            "outputLogs": "new-only"
        },
        "@gtkx/react#build": {
            "dependsOn": ["^build", "//#codegen:run"],
            "inputs": ["package.json", "src/**/*.ts", "src/**/*.tsx", "tsconfig.json", "tsconfig.lib.json"],
            "outputs": ["dist/**", "out-tsc/**", "*.tsbuildinfo", "README.md"],
            "outputLogs": "new-only"
        },
        "@gtkx/ffi#typecheck": {
            "dependsOn": ["^build", "//#codegen:run"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json", "tsconfig.app.json"],
            "outputs": [],
            "outputLogs": "new-only"
        },
        "@gtkx/react#typecheck": {
            "dependsOn": ["^build", "//#codegen:run"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json", "tsconfig.app.json"],
            "outputs": [],
            "outputLogs": "new-only"
        },
        "website#build": {
            "dependsOn": ["@gtkx/ffi#build", "@gtkx/react#build"],
            "inputs": [
                "package.json",
                ".vitepress/**",
                "guide/**",
                "index.md",
                "public/**",
                "scripts/**",
                "tsconfig.json"
            ],
            "outputs": [".vitepress/dist/**", "api/**"],
            "outputLogs": "new-only"
        },
        "website#dev": {
            "dependsOn": ["@gtkx/ffi#build", "@gtkx/react#build"],
            "persistent": true,
            "cache": false
        }
    }
}
