{
    "name": "@gtkx/native",
    "version": "0.21.0",
    "description": "Rust-based native module providing FFI bindings for GTKX",
    "keywords": [
        "gtkx",
        "gtk",
        "gtk4",
        "native",
        "ffi",
        "rust",
        "napi",
        "linux",
        "desktop"
    ],
    "homepage": "https://gtkx.dev",
    "bugs": {
        "url": "https://github.com/gtkx-org/gtkx/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/gtkx-org/gtkx.git",
        "directory": "packages/native"
    },
    "license": "MPL-2.0",
    "author": "Eugenio Depalo <eugeniodepalo@gmail.com>",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "index.ts",
        "types.ts",
        "native-binding.cjs",
        "native-binding.d.cts"
    ],
    "napi": {
        "binaryName": "native",
        "targets": [
            "x86_64-unknown-linux-gnu",
            "aarch64-unknown-linux-gnu"
        ]
    },
    "scripts": {
        "artifacts": "napi artifacts",
        "build": "tsc -b && cp ../../README.md . && cp native-binding.cjs native-binding.d.cts dist/",
        "create-npm-dirs": "napi create-npm-dirs",
        "lint": "cargo fmt --check && cargo clippy -- -D warnings",
        "native-build": "napi build --platform --release --js native-binding.cjs --dts native-binding.d.cts && cp native.linux-$(node -p \"process.arch\")-gnu.node ../native-linux-$(node -p \"process.arch\")-gnu/",
        "coverage": "vitest run --coverage",
        "native-coverage": "mkdir -p coverage && xvfb-run -a cargo llvm-cov --lcov --output-path coverage/native.lcov.info -- --test-threads=1",
        "native-test": "xvfb-run -a cargo test -- --test-threads=1",
        "prepublishOnly": "napi prepublish -t npm",
        "test": "vitest run",
        "typecheck": "tsc -b --emitDeclarationOnly"
    },
    "optionalDependencies": {
        "@gtkx/native-linux-arm64-gnu": "workspace:*",
        "@gtkx/native-linux-x64-gnu": "workspace:*"
    },
    "devDependencies": {
        "@gtkx/vitest": "workspace:*",
        "@napi-rs/cli": "^3"
    }
}
